          },
          "enabled": {
            "type": "bool",
            "description": "启用该账号",
            "default": true
          },
          "school_name": {
            "type": "string",
            "description": "学校名称",
            "hint": "请填写完整学校名称，学校代码会自动解析。",
            "default": ""
          },
          "student_account": {
            "type": "string",
            "description": "完美校园学号",
            "hint": "按字符串填写，前导零会被保留。",
            "default": ""
          }
        }
      }
    }
